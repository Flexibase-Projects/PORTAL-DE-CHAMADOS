{
  "name": "portal-chamados-backend",
  "version": "1.0.0",
  "description": "Backend API para Portal de Chamados",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "kill-port": "node scripts/kill-port.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:coverage": "c8 --check-coverage --lines 85 --functions 85 --branches 75 --include \"src/middleware/**/*.js\" node --test \"tests/**/*.test.js\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "nodemon": "^3.0.2"
  }
}
